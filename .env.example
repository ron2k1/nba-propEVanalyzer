# Optional: The Odds API key (enables odds/auto-sweep/starter-accuracy features)
ODDS_API_KEY=

# Optional: SportsDataIO API key (enables SportsDataIO local backfill script)
SPORTSDATA_API_KEY=

# Optional: News API key (enables injury/news features)
NEWS_API_KEY=

# Optional: Anthropic fallback for LLM analysis when local Ollama is unavailable
ANTHROPIC_API_KEY=

# Optional: provider priority for runtime LLM calls:
#   ollama_first (default) | claude_first
LLM_PROVIDER_ORDER=ollama_first
