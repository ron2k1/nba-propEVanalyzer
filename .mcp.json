{
  "mcpServers": {
    "n8n-mcp": {
      "command": "cmd",
      "args": ["/c", "npx", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio"
      }
    },
    "context7": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
    },
    "lightrag": {
      "command": "cmd",
      "args": ["/c", ".venv\\Scripts\\python.exe", "-m", "lightrag_mcp", "--host", "localhost", "--port", "9621"],
      "env": {}
    }
  }
}
